# =============================================================================
# AccountEngine — Environment Variables
# Copy to .env.local for local development.
# Never commit .env.local to version control.
# =============================================================================

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Vault encryption keys ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# On key rotation: add AE_VAULT_KEY_V2, then re-encrypt existing values
AE_VAULT_KEY=your-32-byte-hex-key-here

# ── Inngest ───────────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=signkey-prod-...

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@accountengine.se

# ── Stripe webhooks ───────────────────────────────────────────────────────────
# Per-integration Stripe keys are stored encrypted in the integrations table.
# Only the webhook secret for AccountEngine's own billing goes here.
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App ───────────────────────────────────────────────────────────────────────
# Publik URL — sätt i Vercel env till din produktions-URL. Inga hemligheter här.
NEXT_PUBLIC_APP_URL=https://accountengine.vercel.app
NODE_ENV=development
