# Copy to .env.local and fill in real values
# Generate AE_ENCRYPTION_KEY with: openssl rand -base64 32

# Supabase — from supabase.com → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Encryption — NEVER lose this key
AE_ENCRYPTION_KEY=

# Fortnox — from developer.fortnox.se
FORTNOX_CLIENT_ID=
FORTNOX_CLIENT_SECRET=
FORTNOX_REDIRECT_URI=http://localhost:3000/api/fortnox/callback

# Temporärt: Fortnox-synk är avstängd som default
FORTNOX_SYNC_ENABLED=false

# Inngest — from app.inngest.com → Settings → Keys
INNGEST_EVENT_KEY=evt_...
INNGEST_SIGNING_KEY=signkey-prod-...

# Anthropic — from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Resend — from resend.com
RESEND_API_KEY=re_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
