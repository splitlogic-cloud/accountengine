{
  "name": "accountengine",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev":          "next dev",
    "build":        "next build",
    "start":        "next start",
    "lint":         "next lint",
    "type-check":   "tsc --noEmit",
    "test":         "vitest run",
    "test:watch":   "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate":   "supabase db push",
    "db:reset":     "supabase db reset",
    "db:types":     "supabase gen types typescript --local > src/types/supabase.ts",
    "db:seed":      "npx tsx scripts/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk":    "^0.39.0",
    "@supabase/ssr":        "^0.6.1",
    "@supabase/supabase-js":"^2.49.1",
    "inngest":              "^3.29.0",
    "next":                 "15.5.14",
    "react":                "^19.0.0",
    "react-dom":            "^19.0.0",
    "stripe":               "^17.7.0"
  },
  "devDependencies": {
    "@types/node":          "^22",
    "@types/react":         "^19",
    "@types/react-dom":     "^19",
    "@vitest/coverage-v8":  "^3.1.1",
    "autoprefixer":         "^10.4.21",
    "postcss":              "^8.5.3",
    "tailwindcss":          "^3.4.17",
    "typescript":           "^5",
    "vitest":               "^3.1.1"
  }
}
